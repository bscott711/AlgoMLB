	systemctl --user stop fadegoblin-post.timer || true
	systemctl --user disable fadegoblin-post.timer || true
	rm -f ~/.config/systemd/user/fadegoblin-post.service
	rm -f ~/.config/systemd/user/fadegoblin-post.timer
	systemctl --user daemon-reload
	@echo "✅ Bot scheduler uninstalled."

# Check the status of the bot scheduler
check-bot-scheduler:
