# 11. STRATEGY & SOCIAL (FadeGoblin)
# ==========================================

# Run the FAST DAILY PIPELINE (Ingest -> Strategy -> Post)
# This is the master command for 6:00 AM Mountain Time (EXCLUDES slow MC sims)
uranium-day:
	@echo "🏟️ Launching Fast Daily Pipeline..."
	PYTHONPATH=src uv run python scripts/daily_uranium_pipeline.py

# Settle bets for a specific date
settle-day date:
	@echo "💰 Settling bets for {{date}}..."
	uv run algomlb settle --date {{date}}

# Settle yesterday's bets
settle-yesterday:
	just settle-day $(date -d "yesterday" +%Y-%m-%d)

# Trigger a FadeGoblin Sniper post manually (if +EV bets exist)
post-sniper:
	@echo "👺 Triggering manual Sniper post with browser automation (Unique content)..."
	xvfb-run --auto-servernum --server-args="-screen 0 1280x800x24" env PYTHONPATH=fadegoblin_playwright/src .venv/bin/python fadegoblin_playwright/src/fadegoblin/main.py --mode sniper

# Trigger a FadeGoblin Degen post manually (Random Parlay)
post-degen:
	@echo "🎲 Triggering manual Degen post with browser automation (Unique content)..."
	xvfb-run --auto-servernum --server-args="-screen 0 1280x800x24" env PYTHONPATH=fadegoblin_playwright/src .venv/bin/python fadegoblin_playwright/src/fadegoblin/main.py --mode degen

# Trigger a FadeGoblin Nightly Recap post manually (uses yesterday's results)
post-recap:
	@echo "📊 Triggering manual Recap post..."
	xvfb-run --auto-servernum --server-args="-screen 0 1280x800x24" env PYTHONPATH=fadegoblin_playwright/src .venv/bin/python fadegoblin_playwright/src/fadegoblin/main.py --mode recap

# Trigger a recap for a specific date (e.g. just post-recap-date 2026-05-16)
post-recap-date date:
	@echo "📊 Triggering Recap post for {{date}}..."
	xvfb-run --auto-servernum --server-args="-screen 0 1280x800x24" env PYTHONPATH=fadegoblin_playwright/src .venv/bin/python fadegoblin_playwright/src/fadegoblin/main.py --mode recap --date {{date}}

# Dry-run the recap (no actual posting)
recap-dry:
	@echo "🧪 Dry-run Recap post (no posting)..."
	env PYTHONPATH=fadegoblin_playwright/src .venv/bin/python fadegoblin_playwright/src/fadegoblin/main.py --mode recap --dry-run

# Trigger a FadeGoblin Night POTD Preview post manually (tonight's upcoming pick)
post-night:
	@echo "🌙 Triggering manual Night POTD Preview post..."
	xvfb-run --auto-servernum --server-args="-screen 0 1280x800x24" env PYTHONPATH=fadegoblin_playwright/src .venv/bin/python fadegoblin_playwright/src/fadegoblin/main.py --mode preview

# Dry-run the night preview (no actual posting)
night-dry:
	@echo "🧪 Dry-run Night Preview (no posting)..."
	env PYTHONPATH=fadegoblin_playwright/src .venv/bin/python fadegoblin_playwright/src/fadegoblin/main.py --mode preview --dry-run

# Trigger a FadeGoblin Social Followup and Grading cycle manually
post-followup:
	@echo "⚖️ Grading completed slips and posting replies..."
	xvfb-run --auto-servernum --server-args="-screen 0 1280x800x24" env PYTHONPATH=fadegoblin_playwright/src .venv/bin/python fadegoblin_playwright/src/fadegoblin/main.py --mode followup

# Dry-run the followup cycle (no posting/database writes)
followup-dry:
	@echo "🧪 Dry-run Degen and POTD followup..."
	env PYTHONPATH=fadegoblin_playwright/src .venv/bin/python fadegoblin_playwright/src/fadegoblin/main.py --mode followup --dry-run

