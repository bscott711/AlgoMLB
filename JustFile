set shell := ["bash", "-c"]

# Default command for the fast loop
default: verify

# ==========================================
# 1. THE AGENT'S TOOLKIT (Self-Correction)
# ==========================================

# Format code (Ruff)
format:
	@echo "🎨 Formatting code..."
	uv run ruff format .

# Lint and fix code (Ruff) and check Markdown (pymarkdownlnt)
lint:
	@echo "🧹 Linting code..."
	uv run ruff check --fix .
	@echo "📝 Linting markdown..."
	uv run pymarkdown --config .pymarkdownrc scan -e "prompts/**" -e "planning_docs/**" -e "**/.agent/**" -e "src/agents/**" -e ".antigravity/**" -e "**/.venv/**" -e "**/.git/**" -e "**/.pytest_cache/**" -e "**/__pycache__/**" -e "**/.ruff_cache/**" -r .

# Strict type checking (Pyright)
check-types:
	@echo "🔒 Checking types..."
	uv run pyright

# Enforce architectural boundaries (Import Linter)
contracts:
	@echo "🏛️ Checking architectural layer contracts..."
	uv run lint-imports

# Detect dead code and unused dependencies
check-deps:
	@echo "🗑️ Checking for unused dependencies and dead code..."
	uv run deptry src -i DEP002
	uv run vulture src tests .vulture_whitelist.py --min-confidence 80

# Check architectural complexity (Cyclomatic Complexity)
check-complexity:
	@echo "📐 Checking architectural complexity..."
	uv run complexipy src/

# Clean up caches and build artifacts
clean:
	@echo "🧼 Cleaning up..."
	rm -rf .pytest_cache .ruff_cache .coverage
	find . -type d -name "__pycache__" -exec rm -rf {} +

# Install pre-commit hooks
install-hooks:
	@echo "🪝 Installing git hooks..."
	uv run pre-commit install

# ==========================================
# 2. THE VERIFICATION LOOPS (Agent Checkpoints)
# ==========================================

# THE FULL GATE: Used by the Orchestrator/Pre-Commit. Runs EVERYTHING.
verify: format lint check-types check-deps contracts check-complexity test-unit

# Run tests with strict 100% coverage limit targeted at the core domain
test-unit:
	@echo "🧪 Running strict unit tests..."
	uv run pytest tests/unit --cov=src --cov-fail-under=100 -n auto

# Run full end-to-end pipeline tests (slow, expensive)
test-e2e:
	@echo "🏁 Running E2E tests..."
	uv run pytest tests/e2e

# ==========================================
# 3. DATABASE MIGRATIONS (Alembic)
# ==========================================

# Apply all pending migrations
migrate:
	@echo "🗄️ Applying database migrations..."
	PYTHONPATH=src uv run alembic upgrade head

# Rollback the last migration
rollback:
	@echo "⏪ Rolling back last migration..."
	PYTHONPATH=src uv run alembic downgrade -1

# Generate a new migration based on ORM changes
revision message:
	@echo "📝 Generating new database revision: {{message}}"
	PYTHONPATH=src uv run alembic revision --autogenerate -m "{{message}}"

# ==========================================
# 4. PRODUCTION OPTIMIZATION (Alpha Search)
# ==========================================

# Run full Moneyline re-calibration (ML calibration + Strategy tuning)
optimize-moneyline:
	@echo "🚀 Launching Full Moneyline Optimization Pipeline..."
	uv run python -m src.ml.optimize --market Moneyline --deep --restart

# Run full Runline/Totals re-calibration (ML calibration + Strategy tuning)
optimize-runline:
	@echo "🚀 Launching Full Runline Optimization Pipeline..."
	uv run python -m src.ml.optimize --market Runline --deep --restart

# Calculate the public IP address for the dashboard URL
public-ip := `curl -s --connect-timeout 2 https://ifconfig.me || echo "unknown"`

# Launch the Streamlit dashboard in the foreground
dashboard:
	@echo "📊 Launching Baseball Bot Dashboard (Port 8502)..."
	uv run streamlit run src/algomlb/ui/app.py --server.port 8502 --server.address 0.0.0.0 --server.headless false

# Alias for dashboard
serve-dashboard: dashboard

# Start or attach to a tmux session named 'dashboard'
dashboard-session:
	@tmux has-session -t dashboard 2>/dev/null || tmux new-session -d -s dashboard 'just dashboard'
	@tmux attach-session -t dashboard

# Launch the Streamlit dashboard in the background
serve-bg:
	@echo "🚀 Launching Baseball Bot Dashboard in the background (Port 8502)..."
	@mkdir -p logs
	@nohup uv run streamlit run src/algomlb/ui/app.py --server.port 8502 --server.address 0.0.0.0 --server.headless true > logs/dashboard.log 2>&1 & echo $! > logs/dashboard.pid
	@echo "✅ Dashboard started! PID saved to logs/dashboard.pid."
	@echo "🔗 Local URL:  http://localhost:8502"
	@echo "🔗 Public URL: http://{{public-ip}}:8502"
	@echo "📝 Use 'just tail-logs' to monitor startup."

# Stop the background dashboard
stop-bg:
	@echo "🛑 Stopping background dashboard..."
	@if [ -f logs/dashboard.pid ]; then \
		kill -9 $(cat logs/dashboard.pid) 2>/dev/null || true; \
		rm logs/dashboard.pid; \
	fi
	@pkill -9 -f "streamlit run src/algomlb/ui/app.py" 2>/dev/null || true
	@echo "✅ Stopped."

# Monitor the background dashboard logs
tail-logs:
	@tail -f logs/dashboard.log

# ==========================================
# 5. DATABASE HEALTH (P0 Foundation)
# ==========================================

# Run functional database health tests (requires live DB)
test-db:
	@echo "🧪 Running functional DB health tests..."
	uv run pytest -m functional tests/functional/db/

# Generate a CLI health report of the database schema
db-health-summary:
	@echo "📡 Generating Database Health Summary..."
	PYTHONPATH=src uv run python scripts/db_health_summary.py

# Commit all changes with a message
commit message:
	git add .
	git commit -m "{{message}}"

# Commit all changes and push to remote
sync message:
	git add .
	git commit -m "{{message}}"
	git push

# ==========================================
# 6. STATCAST INGESTION (Epic 1)
# ==========================================

# Fetch and ingest Statcast for a date range (dry-run by default)
demo-statcast:
	@echo "📡 Running Statcast dry-run fetch..."
	uv run algomlb ingest statcast --start 2025-04-01 --end 2025-04-07 --dry-run

# Ingest Statcast for today (live write)
ingest-statcast-today:
	@echo "🚀 Ingesting today's Statcast events..."
	uv run algomlb ingest statcast --start $(date +%Y-%m-%d)

# Backfill a full season (will be slow — run in tmux or nohup)
backfill-statcast year='2024':
	@echo "📅 Backfilling Statcast for {{year}} season..."
	uv run algomlb ingest statcast --start {{year}}-03-20 --end {{year}}-11-05
# ==========================================
# 7. SILVER LAYER (Medallion Epic 2.3)
# ==========================================

# Process silver game logs for a full year
process-silver-year year="2025":
    uv run algomlb process silver --year {{year}}

# Process silver game logs for all historical years (2019-2024)
process-silver-full-history:
    @for year in 2019 2020 2021 2022 2023 2024; do \
        echo "📅 Processing Silver for $year..."; \
        uv run algomlb process silver --year $year; \
    done

# Process Silver Layer (Game Logs)
process-silver:
    uv run algomlb process silver

# Process Rolling Features (Gold Layer) for a date range
roll start end:
    uv run algomlb process rolling --start {{start}} --end {{end}}

# Process Gold rolling features for the entire history (2019-2024)
roll-full-history:
    @for year in 2019 2020 2021 2022 2023 2024; do \
        echo "🏆 Processing Gold Rolling Features for $year..."; \
        uv run algomlb process rolling --start $year-03-20 --end $year-11-05; \
    done

# Backfill example for 2024 season
roll-backfill-2024:
    uv run algomlb process rolling --start 2024-03-20 --end 2024-10-01

# Process rolling features for today
roll-today:
    uv run algomlb process rolling --date $(date +%Y-%m-%d)

# Dry-run rolling features for a date
roll-dry date:
    uv run algomlb process rolling --date {{date}} --dry-run

# Process silver logs for today
process-silver-today:
    uv run algomlb process silver --date $(date +%Y-%m-%d)

# Perform incremental silver processing (High-Water Mark)
process-silver-incremental:
    uv run algomlb process silver --incremental

# ==========================================
# 8. THE MASTER SYNC (Sync Everything)
# ==========================================

# Synchronize ALL data (Lineups, Statcast, Weather, Silver, Gold) for a given year
# Usage: just sync-season 2024
sync-season year:
	@echo "🏟️ Synchronizing Full Season Pipeline for {{year}} (inc. Postseason)..."
	@echo "--- 1/5: Ingesting Starting Lineups ---"
	uv run algomlb ingest lineups --start {{year}}-03-01 --end {{year}}-11-15 --throttle 100
	@echo "--- 2/5: Ingesting Statcast Raw Events ---"
	uv run algomlb ingest statcast --start {{year}}-03-01 --end {{year}}-11-15
	@echo "--- 3/5: Ingesting OpenMeteo Weather Data ---"
	uv run algomlb ingest weather --start {{year}}-03-01 --end {{year}}-11-15
	@echo "--- 4/5: Materializing Silver Game Logs ---"
	uv run algomlb process silver --year {{year}}
	@echo "--- 5/5: Materializing Gold Rolling Features ---"
	uv run algomlb process rolling --start {{year}}-03-01 --end {{year}}-11-15
	@echo "✅ Season {{year}} Sync Complete!"

# Synchronize full historical range (2019-2025)
sync-full-history:
	@for year in 2026 2025 2024 2023 2022 2021 2020 2019; do \
		just sync-season $year; \
	done
	@echo "🏆 Full History Sync Complete!"
