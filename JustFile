# Batch simulate all games for a specific date
# Usage: just sim-day 2026-05-13
sim-day date:
	@echo "🤖 Batch simulating all games for {{date}}..."
	PYTHONPATH=src uv run python src/algomlb/cli/main.py ml sim-day {{date}}

# Shortcut to simulate today's slate
sim-today:
	just sim-day $(date +%Y-%m-%d)

# Run Uranium Monte Carlo simulations for today's slate (Background/Heavy)
sim-uranium:
	@echo "🛸 Running high-fidelity Uranium MC simulations..."
	just sim-today

