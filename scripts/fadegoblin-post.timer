[Unit]
Description=Timer for FadeGoblin Daily Social Post (Sniper)
RefuseManualStart=no
RefuseManualStop=no

[Timer]
# Run every day at 12:30 UTC = 6:30 AM MDT / 5:30 AM MST
# Morning card: picks for today's games posted as followers wake up
OnCalendar=*-*-* 12:30:00
Unit=fadegoblin-post.service
Persistent=true

[Install]
WantedBy=timers.target
