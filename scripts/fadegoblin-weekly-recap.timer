[Unit]
Description=Timer for FadeGoblin Weekly Recap Post
RefuseManualStart=no
RefuseManualStop=no

[Timer]
# Run every Monday at 12:15 UTC = 6:15 AM MDT / 5:15 AM MST
# Settle fires at 11:30 UTC, daily recap fires at 12:00 UTC.
# This fires 15 min after the Monday daily recap, summarizing the past 7 days (Mon-Sun).
OnCalendar=Mon *-*-* 12:15:00
Unit=fadegoblin-weekly-recap.service
Persistent=true

[Install]
WantedBy=timers.target
