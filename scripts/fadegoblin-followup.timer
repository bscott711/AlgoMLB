[Unit]
Description=Timer for FadeGoblin Social Followup and Grading Cycle
RefuseManualStart=no
RefuseManualStop=no

[Timer]
# Run every 2 hours (UTC) to check and reply to completed games
OnCalendar=00,02,04,06,08,10,12,14,16,18,20,22:00:00
Unit=fadegoblin-followup.service
Persistent=true

[Install]
WantedBy=timers.target
